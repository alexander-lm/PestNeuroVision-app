<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/detectorFragment">

    <fragment
        android:id="@+id/detectorFragment"
        android:name="com.example.projectinvasiveinsects.ui.DetectorFragment"
        android:label="fragment_detector"
        tools:layout="@layout/fragment_detector" />
    <fragment
        android:id="@+id/historyFragment"
        android:name="com.example.projectinvasiveinsects.ui.HistoryFragment"
        android:label="fragment_history"
        tools:layout="@layout/fragment_history">
        <action
            android:id="@+id/action_historyFragment_to_informationFragment"
            app:destination="@id/informationFragment"/>
    </fragment>

    <fragment
        android:id="@+id/insectListFragment"
        android:name="com.example.projectinvasiveinsects.ui.InsectListFragment"
        android:label="fragment_insect_list"
        tools:layout="@layout/fragment_insect_list">
        <action
            android:id="@+id/action_insectListFragment_to_informationFragment"
            app:destination="@id/informationFragment"/>
    </fragment>

    <fragment
        android:id="@+id/informationFragment"
        android:name="com.example.projectinvasiveinsects.ui.InformationFragment"
        android:label="fragment_information"
        tools:layout="@layout/fragment_information" />

    <fragment
        android:id="@+id/graphFragment"
        android:name="com.example.projectinvasiveinsects.ui.GraphFragment"
        android:label="fragment_graph"
        tools:layout="@layout/fragment_graph" />

    <fragment
        android:id="@+id/aboutFragment"
        android:name="com.example.projectinvasiveinsects.ui.AboutFragment"
        android:label="Acerca de"
        tools:layout="@layout/fragment_about" />

    <fragment
        android:id="@+id/accountFragment"
        android:name="com.example.projectinvasiveinsects.ui.AccountFragment"
        android:label="Mi Cuenta"
        tools:layout="@layout/fragment_account" />



</navigation>